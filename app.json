{
  "expo": {
    "name": "DrypSkin",
    "slug": "drypskin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "drypskin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.drypskin.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.drypskin.app",
      "versionCode": 1,
      "permissions": ["android.permission.INTERNET"]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#f1eee7",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#f1eee7"
          },
          "imageWidth": 200
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
